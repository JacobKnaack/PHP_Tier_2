{
    "name": "jacobk/php_tier_2",
    "description": "PHP Exercises using web servers",
    "type": "project",
    "autoload": {
        "psr-4": {
            "Jacobk\\PhpTier2\\": "src/",
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "JacobKnaack",
            "email": "jacobk@hostwinds.net"
        }
    ],
    "scripts": {
        "start": "@php -S 127.0.0.1:8888 -t public/",
        "test": "@php ./watch_tests.php"
    },
    "config": {
        "process-timeout": 0
    },
    "minimum-stability": "stable",
    "require": {
        "erusev/parsedown": "^1.8",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1"
    }
}
